---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  ogTitle?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  tags?: string[];
  lang?: string;
}

const {
  title,
  description,
  canonical,
  image = '/og-default.png',
  ogTitle,
  type = 'website',
  publishedTime,
  tags = [],
  lang,
} = Astro.props;

const siteUrl = 'https://lopezkristian.com';
const canonicalUrl = canonical ?? Astro.url.href;
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;
const fullTitle = title.includes('Kristian') ? title : `${title} | Kristian López`;
const socialTitle = ogTitle ?? fullTitle;
const ogLocaleMap: Record<string, string> = {
  en: 'en_US',
  es: 'es_ES',
};
const ogLocale = ogLocaleMap[lang ?? 'en'] ?? 'en_US';
const fbAppId = import.meta.env.PUBLIC_FB_APP_ID;
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<!-- OpenGraph -->
{fbAppId && <meta property="fb:app_id" content={fbAppId} />}
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={socialTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={socialTitle} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:site_name" content="Kristian López" />

<!-- Twitter Cards -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={socialTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

{
  type === 'article' && publishedTime && (
    <meta property="article:published_time" content={publishedTime} />
  )
}
{tags.map((tag) => <meta property="article:tag" content={tag} />)}
