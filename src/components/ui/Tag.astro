---
interface Props {
  label: string;
  href?: string;
  active?: boolean;
}
const { label, href, active = false } = Astro.props;
const baseClass = `inline-flex items-center rounded-full px-3 py-1 text-xs font-medium transition-colors ${
  active
    ? 'bg-violet-600 text-white'
    : 'bg-white/5 text-[#9ca3af] hover:bg-violet-600/20 hover:text-violet-400'
}`;
---

{href ? (
  <a href={href} class={baseClass}>{label}</a>
) : (
  <span class={baseClass}>{label}</span>
)}
