---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth <= 3);
---

{filtered.length > 0 && (
  <nav aria-label="Table of contents" class="rounded-xl border border-white/10 bg-[#111111] p-6">
    <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-[#9ca3af]">
      On this page
    </h2>
    <ul class="space-y-2">
      {filtered.map((heading) => (
        <li class={heading.depth === 3 ? 'ml-4' : ''}>
          <a
            href={`#${heading.slug}`}
            class="text-sm text-[#9ca3af] hover:text-violet-400 transition-colors"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
