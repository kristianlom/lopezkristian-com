---
interface Props {
  title: string;
  description: string;
  href: string;
  tags?: string[];
  date?: Date;
  variant?: 'post' | 'project';
}

const { title, description, href, tags = [], date } = Astro.props;
---

<article class="group relative flex flex-col rounded-xl border border-border bg-surface p-6 transition-all duration-200 hover:border-violet-500/50 hover:shadow-lg hover:shadow-violet-500/5">
  {date && (
    <time class="mb-2 text-xs text-muted" datetime={date.toISOString()}>
      {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>
  )}

  <h3 class="mb-2 text-lg font-semibold text-text-primary group-hover:text-violet-400 transition-colors">
    <a href={href} class="after:absolute after:inset-0">
      {title}
    </a>
  </h3>

  <p class="mb-4 flex-1 text-sm leading-relaxed text-muted">
    {description}
  </p>
  
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="rounded-full bg-violet-600/10 px-2.5 py-0.5 text-xs font-medium text-violet-400">
          {tag}
        </span>
      ))}
    </div>
  )}
</article>
