---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border py-12">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
      <div>
        <p class="text-sm text-muted">
          © {currentYear} Kristian López. All rights reserved.
        </p>
        <p class="mt-1 text-xs text-muted">
          Built with <a href="https://astro.build" class="text-muted hover:text-violet-400 transition-colors">Astro</a> + TypeScript + Tailwind
        </p>
      </div>

      <nav aria-label="Footer navigation">
        <ul class="flex items-center gap-4" role="list">
          <li>
            <a
              href="https://github.com/kristianlom"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-muted hover:text-text-primary transition-colors"
              aria-label="GitHub profile"
            >
              GitHub
            </a>
          </li>
          <li>
            <a
              href="https://linkedin.com/in/lopezkristian"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-muted hover:text-text-primary transition-colors"
              aria-label="LinkedIn profile"
            >
              LinkedIn
            </a>
          </li>
          <li>
            <a href="/writing/rss.xml" class="text-sm text-muted hover:text-text-primary transition-colors" aria-label="RSS feed">
              RSS
            </a>
          </li>
          <li>
            <a href="/privacy" class="text-sm text-muted hover:text-text-primary transition-colors">
              Privacy
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</footer>
