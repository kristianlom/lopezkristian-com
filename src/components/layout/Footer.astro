---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border py-12">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
      <div>
        <p class="text-sm text-muted">
          © {currentYear} Kristian López. All rights reserved.
        </p>
        <p class="mt-1 text-xs text-muted">
          Built with <a
            href="https://astro.build"
            class="text-muted transition-colors hover:text-violet-400">Astro</a
          > + TypeScript + Tailwind
        </p>
      </div>

      <nav aria-label="Footer navigation">
        <ul class="flex items-center gap-4" role="list">
          <li>
            <a
              href="https://github.com/kristianlom"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-muted transition-colors hover:text-text-primary"
              aria-label="GitHub profile"
              data-track-event="external-link"
              data-track-label="GitHub"
            >
              GitHub
            </a>
          </li>
          <li>
            <a
              href="https://linkedin.com/in/lopezkristian"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-muted transition-colors hover:text-text-primary"
              aria-label="LinkedIn profile"
              data-track-event="external-link"
              data-track-label="LinkedIn"
            >
              LinkedIn
            </a>
          </li>
          <li>
            <a
              href="/writing/rss.xml"
              class="text-sm text-muted transition-colors hover:text-text-primary"
              aria-label="RSS feed"
            >
              RSS
            </a>
          </li>
          <li>
            <a href="/privacy" class="text-sm text-muted transition-colors hover:text-text-primary">
              Privacy
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</footer>
