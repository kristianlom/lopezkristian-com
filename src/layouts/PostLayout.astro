---
import BaseLayout from './BaseLayout.astro';
import JsonLd from '@components/seo/JsonLd.astro';
import TableOfContents from '@components/ui/TableOfContents.astro';
import Tag from '@components/ui/Tag.astro';
import { formatDate, isoDate } from '@utils/date';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  heroImage?: string;
  headings?: Array<{ depth: number; slug: string; text: string }>;
  readingTime?: string;
  slug: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  heroImage,
  headings = [],
  readingTime,
  slug,
} = Astro.props;

const postUrl = `https://lopezkristian.com/writing/${slug}`;
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  type="article"
  publishedTime={isoDate(pubDate)}
  tags={tags}
>
  <JsonLd
    type="Article"
    title={title}
    description={description}
    publishedTime={isoDate(pubDate)}
    modifiedTime={updatedDate ? isoDate(updatedDate) : undefined}
    url={postUrl}
  />

  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-12">
      <article class="min-w-0">
        <header class="mb-10">
          <div class="mb-4 flex flex-wrap items-center gap-3">
            <time class="text-sm text-muted" datetime={isoDate(pubDate)}>
              {formatDate(pubDate)}
            </time>
            {updatedDate && (
              <span class="text-sm text-muted">
                · Updated {formatDate(updatedDate)}
              </span>
            )}
            {readingTime && (
              <span class="text-sm text-muted">· {readingTime}</span>
            )}
          </div>

          <h1 class="mb-4 text-3xl font-bold leading-tight text-text-primary sm:text-4xl">
            {title}
          </h1>
          <p class="text-lg text-muted">{description}</p>

          {tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {tags.map((tag) => (
                <Tag label={tag} href={`/writing?tag=${tag}`} />
              ))}
            </div>
          )}
        </header>

        <div class="prose prose-violet max-w-none prose-headings:font-bold prose-headings:text-text-primary prose-p:text-muted prose-li:text-muted prose-a:text-violet-400 prose-strong:text-text-primary prose-code:font-mono prose-pre:rounded-xl prose-img:rounded-xl">
          <slot />
        </div>

        <footer class="mt-12 border-t border-border pt-8">
          <div class="flex items-center gap-4">
            <div>
              <p class="font-semibold text-text-primary">Kristian López</p>
              <p class="text-sm text-muted">Software Architect · Staff Engineer</p>
            </div>
          </div>
        </footer>
      </article>

      <aside class="hidden lg:block">
        <div class="sticky top-24">
          <TableOfContents headings={headings} />
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
