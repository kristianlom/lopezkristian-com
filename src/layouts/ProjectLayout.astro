---
import BaseLayout from './BaseLayout.astro';
import Tag from '@components/ui/Tag.astro';
import CTA from '@components/ui/CTA.astro';
import { formatDate } from '@utils/date';

interface Props {
  title: string;
  description: string;
  stack: string[];
  date: Date;
  status: 'active' | 'archived';
  repoUrl?: string;
}

const { title, description, stack, date, status, repoUrl } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="mx-auto max-w-4xl px-6 py-12">
    <article>
      <header class="mb-10">
        <div class="mb-4 flex items-center gap-3">
          <span class={`rounded-full px-2.5 py-0.5 text-xs font-medium ${
            status === 'active' ? 'bg-green-500/10 text-green-400' : 'bg-white/10 text-[#9ca3af]'
          }`}>
            {status}
          </span>
          <time class="text-sm text-[#9ca3af]" datetime={date.toISOString()}>
            {formatDate(date)}
          </time>
        </div>

        <h1 class="mb-4 text-3xl font-bold text-[#f1f1f1] sm:text-4xl">{title}</h1>
        <p class="text-lg text-[#9ca3af]">{description}</p>

        <div class="mt-6 flex flex-wrap items-center gap-3">
          {stack.map((tech) => (
            <Tag label={tech} />
          ))}
          {repoUrl && (
            <CTA href={repoUrl} variant="secondary" external>
              View on GitHub →
            </CTA>
          )}
        </div>
      </header>

      <div class="prose prose-invert prose-violet max-w-none prose-headings:font-bold prose-a:text-violet-400 prose-code:font-mono prose-pre:rounded-xl">
        <slot />
      </div>
    </article>
  </div>
</BaseLayout>
