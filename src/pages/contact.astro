---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/layout/Section.astro';
---

<BaseLayout
  title="Contact — Kristian López"
  description="Get in touch with Kristian López for software architecture consulting, staff engineering roles, or technical collaborations."
>
  <Section>
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <h1 class="mb-4 text-4xl font-bold text-[#f1f1f1]">Get in Touch</h1>
        <p class="mb-8 text-lg leading-relaxed text-[#9ca3af]">
          I'm open to senior engineering roles, architecture consulting, and interesting 
          technical conversations. Fill out the form or reach me directly.
        </p>

        <div class="space-y-4">
          <a
            href="https://linkedin.com/in/lopezkristian"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 rounded-xl border border-white/10 bg-[#111111] p-4 transition-colors hover:border-violet-500/30"
          >
            <span class="text-2xl" aria-hidden="true">💼</span>
            <div>
              <p class="font-semibold text-[#f1f1f1]">LinkedIn</p>
              <p class="text-sm text-violet-400">linkedin.com/in/lopezkristian</p>
            </div>
          </a>

          <a
            href="https://github.com/kristianlom"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 rounded-xl border border-white/10 bg-[#111111] p-4 transition-colors hover:border-violet-500/30"
          >
            <span class="text-2xl" aria-hidden="true">⚙️</span>
            <div>
              <p class="font-semibold text-[#f1f1f1]">GitHub</p>
              <p class="text-sm text-violet-400">github.com/kristianlom</p>
            </div>
          </a>

          <div class="rounded-xl border border-white/10 bg-[#111111] p-4">
            <p class="font-semibold text-[#f1f1f1]">Schedule a call</p>
            <p class="text-sm text-[#9ca3af]">Calendly integration — coming soon</p>
          </div>
        </div>
      </div>

      <div>
        <form
          id="contact-form"
          class="space-y-6 rounded-xl border border-white/10 bg-[#111111] p-8"
          novalidate
        >
          <div>
            <label for="name" class="mb-2 block text-sm font-medium text-[#f1f1f1]">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-[#f1f1f1] placeholder-[#9ca3af] focus:border-violet-500 focus:outline-none focus:ring-1 focus:ring-violet-500 transition-colors"
              placeholder="Your name"
            />
          </div>

          <div>
            <label for="email" class="mb-2 block text-sm font-medium text-[#f1f1f1]">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-[#f1f1f1] placeholder-[#9ca3af] focus:border-violet-500 focus:outline-none focus:ring-1 focus:ring-violet-500 transition-colors"
              placeholder="you@example.com"
            />
          </div>

          <div>
            <label for="message" class="mb-2 block text-sm font-medium text-[#f1f1f1]">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows={5}
              class="w-full resize-none rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-[#f1f1f1] placeholder-[#9ca3af] focus:border-violet-500 focus:outline-none focus:ring-1 focus:ring-violet-500 transition-colors"
              placeholder="Tell me about the opportunity or project..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full rounded-lg bg-violet-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-violet-600/20 transition-all hover:bg-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:ring-offset-2 focus:ring-offset-[#111111]"
          >
            Send message
          </button>

          <p class="text-xs text-[#9ca3af]">
            This form is ready for serverless integration (Netlify Forms, Formspree, etc.).
          </p>
        </form>
      </div>
    </div>
  </Section>
</BaseLayout>
