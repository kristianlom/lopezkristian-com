---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/layout/Section.astro';

const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<BaseLayout
  title="Contact — Kristian López"
  ogTitle="Contact Kristian López — Architecture Consulting & Engineering Roles"
  description="Get in touch with Kristian López for software architecture consulting, staff engineering roles, or technical collaborations."
  image="/og/og-home.png"
>
  <Section>
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <h1 class="mb-4 text-4xl font-bold text-text-primary">Get in Touch</h1>
        <p class="mb-8 text-lg leading-relaxed text-muted">
          I'm open to senior engineering roles, architecture consulting, and interesting technical
          conversations. Fill out the form or reach me directly.
        </p>

        <div class="space-y-4">
          <a
            href="https://linkedin.com/in/lopezkristian"
            target="_blank"
            rel="noopener noreferrer"
            data-track-event="external-link"
            data-track-label="LinkedIn"
            class="flex items-center gap-4 rounded-xl border border-border bg-surface p-4 transition-colors hover:border-violet-500/30"
          >
            <span class="text-2xl" aria-hidden="true">💼</span>
            <div>
              <p class="font-semibold text-text-primary">LinkedIn</p>
              <p class="text-sm text-violet-400">linkedin.com/in/lopezkristian</p>
            </div>
          </a>

          <a
            href="https://github.com/kristianlom"
            target="_blank"
            rel="noopener noreferrer"
            data-track-event="external-link"
            data-track-label="GitHub"
            class="flex items-center gap-4 rounded-xl border border-border bg-surface p-4 transition-colors hover:border-violet-500/30"
          >
            <span class="text-2xl" aria-hidden="true">⚙️</span>
            <div>
              <p class="font-semibold text-text-primary">GitHub</p>
              <p class="text-sm text-violet-400">github.com/kristianlom</p>
            </div>
          </a>

          <div class="rounded-xl border border-border bg-surface p-4">
            <p class="font-semibold text-text-primary">Response SLA</p>
            <p class="text-sm text-muted">Usually within 24 business hours.</p>
          </div>
        </div>
      </div>

      <div>
        <form
          id="contact-form"
          class="space-y-6 rounded-xl border border-border bg-surface p-8"
          novalidate
        >
          <input type="hidden" name="access_key" value={web3formsKey} />
          <input type="hidden" name="subject" value="New contact from lopezkristian.com" />
          <input type="hidden" name="from_name" value="Portfolio Contact Form" />
          <div class="hidden" aria-hidden="true">
            <label for="botcheck">Botcheck</label>
            <input type="checkbox" id="botcheck" name="botcheck" tabindex="-1" autocomplete="off" />
          </div>

          <div>
            <label for="name" class="mb-2 block text-sm font-medium text-text-primary">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              minlength="2"
              maxlength="80"
              autocomplete="name"
              class="w-full rounded-lg border border-border bg-surface-hover px-4 py-3 text-text-primary placeholder-muted transition-colors focus:border-violet-500 focus:outline-none focus:ring-1 focus:ring-violet-500"
              placeholder="Your name"
            />
          </div>

          <div>
            <label for="email" class="mb-2 block text-sm font-medium text-text-primary">Email</label
            >
            <input
              type="email"
              id="email"
              name="email"
              required
              maxlength="120"
              autocomplete="email"
              class="w-full rounded-lg border border-border bg-surface-hover px-4 py-3 text-text-primary placeholder-muted transition-colors focus:border-violet-500 focus:outline-none focus:ring-1 focus:ring-violet-500"
              placeholder="you@example.com"
            />
          </div>

          <div>
            <label for="message" class="mb-2 block text-sm font-medium text-text-primary"
              >Message</label
            >
            <textarea
              id="message"
              name="message"
              required
              minlength="20"
              maxlength="2000"
              rows={6}
              class="w-full resize-none rounded-lg border border-border bg-surface-hover px-4 py-3 text-text-primary placeholder-muted transition-colors focus:border-violet-500 focus:outline-none focus:ring-1 focus:ring-violet-500"
              placeholder="Tell me about the opportunity or project..."></textarea>
          </div>

          {
            turnstileSiteKey && (
              <div
                class="cf-turnstile"
                data-sitekey={turnstileSiteKey}
                data-theme="auto"
                data-callback="onTurnstileSuccess"
                data-expired-callback="onTurnstileExpired"
              />
            )
          }

          <button
            id="contact-submit"
            type="submit"
            class="w-full rounded-lg bg-violet-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-violet-600/20 transition-all hover:bg-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:ring-offset-2 focus:ring-offset-bg disabled:cursor-not-allowed disabled:opacity-70"
          >
            Send message
          </button>

          <p id="contact-feedback" class="hidden text-sm" role="status" aria-live="polite"></p>

          <p class="text-xs text-muted">
            {
              turnstileSiteKey
                ? 'Protected by Cloudflare Turnstile, honeypot anti-spam, and rate limiting.'
                : 'Protected with client-side validation, honeypot anti-spam, and rate limiting.'
            }
          </p>
        </form>
      </div>
    </div>
  </Section>
</BaseLayout>

{
  turnstileSiteKey && (
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" defer />
  )
}

<script>
  import { track } from '@utils/analytics';

  const RATE_LIMIT_KEY = 'contact_form_attempts';
  const MAX_SUBMISSIONS_PER_HOUR = 3;

  interface TurnstileWindow extends Window {
    onTurnstileSuccess?: (token: string) => void;
    onTurnstileExpired?: () => void;
    turnstile?: { reset: () => void };
  }
  const win = window as TurnstileWindow;

  let turnstileToken = '';

  win.onTurnstileSuccess = (token: string) => {
    turnstileToken = token;
  };
  win.onTurnstileExpired = () => {
    turnstileToken = '';
  };

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitButton = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const feedback = document.getElementById('contact-feedback');
  const turnstileEnabled = !!form?.querySelector('.cf-turnstile');

  if (form) {
    const nameField = form.querySelector<HTMLInputElement>('#name');
    const emailField = form.querySelector<HTMLInputElement>('#email');
    const messageField = form.querySelector<HTMLTextAreaElement>('#message');
    const fields = [nameField, emailField, messageField].filter(Boolean) as Array<
      HTMLInputElement | HTMLTextAreaElement
    >;

    function clearFeedback() {
      if (!feedback) return;
      feedback.classList.add('hidden');
      feedback.classList.remove('text-green-400', 'text-red-400');
      feedback.textContent = '';
    }

    function setFeedback(message: string, type: 'success' | 'error') {
      if (!feedback) return;
      feedback.classList.remove('hidden', 'text-green-400', 'text-red-400');
      feedback.classList.add(type === 'success' ? 'text-green-400' : 'text-red-400');
      feedback.textContent = message;
    }

    function showError(field: HTMLInputElement | HTMLTextAreaElement, message: string) {
      clearError(field);
      const error = document.createElement('p');
      error.className = 'mt-1 text-xs text-red-500';
      error.setAttribute('role', 'alert');
      error.textContent = message;
      field.parentElement?.appendChild(error);
      field.classList.add('border-red-500');
      field.setAttribute('aria-invalid', 'true');
    }

    function clearError(field: HTMLInputElement | HTMLTextAreaElement) {
      const existing = field.parentElement?.querySelector('[role="alert"]');
      existing?.remove();
      field.classList.remove('border-red-500');
      field.removeAttribute('aria-invalid');
    }

    function validateField(field: HTMLInputElement | HTMLTextAreaElement): boolean {
      clearError(field);
      const value = field.value.trim();

      if (!value) {
        showError(field, `${field.labels?.[0]?.textContent ?? 'This field'} is required.`);
        return false;
      }

      if (field.id === 'name' && value.length < 2) {
        showError(field, 'Name must be at least 2 characters.');
        return false;
      }

      if (field.id === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value)) {
        showError(field, 'Please enter a valid email address.');
        return false;
      }

      if (field.id === 'message' && value.length < 20) {
        showError(field, 'Message must be at least 20 characters.');
        return false;
      }

      return true;
    }

    function getRecentAttempts(): number[] {
      try {
        const parsed = JSON.parse(localStorage.getItem(RATE_LIMIT_KEY) ?? '[]');
        if (!Array.isArray(parsed)) return [];
        const oneHourAgo = Date.now() - 60 * 60 * 1000;
        return parsed.filter((value) => Number.isFinite(value) && value > oneHourAgo);
      } catch {
        return [];
      }
    }

    function canSubmitNow() {
      return getRecentAttempts().length < MAX_SUBMISSIONS_PER_HOUR;
    }

    function registerAttempt() {
      const attempts = [...getRecentAttempts(), Date.now()];
      try {
        localStorage.setItem(RATE_LIMIT_KEY, JSON.stringify(attempts));
      } catch {
        // Swallow errors: failure to persist attempts should not block submission
      }
    }

    fields.forEach((field) => {
      field.addEventListener('blur', () => validateField(field));
      field.addEventListener('input', () => {
        clearFeedback();
        if (field.getAttribute('aria-invalid') === 'true') validateField(field);
      });
    });

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearFeedback();

      let valid = true;
      fields.forEach((field) => {
        if (!validateField(field)) valid = false;
      });

      if (!valid) return;

      if (!canSubmitNow()) {
        setFeedback('Rate limit reached. Please wait before sending another message.', 'error');
        return;
      }

      if (turnstileEnabled && !turnstileToken) {
        setFeedback('Please complete the security check.', 'error');
        return;
      }

      if (submitButton) {
        submitButton.disabled = true;
        submitButton.textContent = 'Sending...';
      }

      try {
        const formData = new FormData(form);
        if (turnstileToken) {
          formData.append('cf_turnstile_response', turnstileToken);
        }
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData,
        });

        const data = await response.json().catch(() => ({}));

        if (!response.ok || !data.success) {
          setFeedback(
            data?.message ?? 'Unable to send your message right now. Try again later.',
            'error'
          );
          return;
        }

        registerAttempt();
        form.reset();
        if (win.turnstile) {
          win.turnstile.reset();
        }
        turnstileToken = '';
        setFeedback('Message sent successfully. Thanks for reaching out.', 'success');
        track('contact-submit', {});
      } catch {
        setFeedback('Network error while sending message. Please try again.', 'error');
      } finally {
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.textContent = 'Send message';
        }
      }
    });
  }
</script>
