---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/layout/Section.astro';
import Tag from '@components/ui/Tag.astro';
---

<BaseLayout
  title="Resume — Kristian López"
  ogTitle="Resume — Kristian López | Software Architect & Staff Engineer"
  description="Resume of Kristian López: architecture leadership, backend engineering, cloud platforms, and delivery impact."
  image="/og/og-about.png"
>
  <Section>
    <div class="mb-8 flex items-start justify-between gap-4">
      <div>
        <h1 class="mb-2 text-4xl font-bold text-text-primary">Kristian López</h1>
        <p class="text-lg text-muted">Software Architect (Java | AWS | Docker)</p>
        <p class="mt-1 text-sm text-muted">Ciudad de México, México</p>
      </div>
      <a
        href="/Kristian_Lopez_Resume.pdf"
        target="_blank"
        rel="noopener noreferrer"
        data-track-event="cv-download"
        data-track-label="Download PDF"
        class="inline-flex items-center gap-2 rounded-lg border border-border px-6 py-3 text-sm font-semibold text-text-primary transition-colors hover:border-violet-500/40 hover:text-violet-400 print:hidden"
      >
        Download PDF
      </a>
    </div>

    <div class="mb-12 rounded-xl border border-border bg-surface p-6">
      <h2 class="mb-3 text-xl font-bold text-text-primary">Professional Summary</h2>
      <p class="text-sm leading-relaxed text-muted">
        Results-driven Software Architect and Technical Leader with over 9 years of experience
        designing and implementing cloud-native architectures and microservices solutions using
        Java, Go, Python, and Rust. Proven track record leading teams of 4–8 engineers to deliver
        scalable, secure, and high-performance systems on AWS. Skilled in software optimisation,
        CI/CD automation, and clean architecture principles, with a strong focus on reliability,
        performance, and collaboration across multidisciplinary teams.
      </p>
    </div>

    <div class="mb-12">
      <h2 class="mb-6 text-xl font-bold text-text-primary">Experience</h2>
      <div class="space-y-6">
        <div class="rounded-xl border border-border bg-surface p-6">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="font-semibold text-text-primary">Software Architect</h3>
              <p class="text-muted">Smart Payment Services</p>
            </div>
            <span class="shrink-0 font-mono text-sm text-violet-400">Feb 2025 – Oct 2025</span>
          </div>
          <ul class="mt-3 space-y-1 text-sm text-muted">
            <li>
              • Designed and implemented a microservices architecture on AWS, leveraging
              multi-language solutions using Rust, Java, Go, and Python to optimise system
              scalability and performance
            </li>
            <li>
              • Established and enforced best development practices, conducting code reviews focused
              on maintainability, security, and performance
            </li>
            <li>
              • Integrated SonarQube for automated code analysis and dependency security
              verification, improving code quality and reducing vulnerabilities across multiple
              projects
            </li>
          </ul>
          <div class="mt-4 flex flex-wrap gap-2">
            {['Rust', 'Java', 'Go', 'Python', 'AWS', 'SonarQube'].map((t) => <Tag label={t} />)}
          </div>
        </div>

        <div class="rounded-xl border border-border bg-surface p-6">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="font-semibold text-text-primary">Software Engineer</h3>
              <p class="text-muted">Smart Payment Services</p>
            </div>
            <span class="shrink-0 font-mono text-sm text-violet-400">Jul 2024 – Feb 2025</span>
          </div>
          <ul class="mt-3 space-y-1 text-sm text-muted">
            <li>
              • Developed microservices using Java (Eclipse Vert.x and Spring Boot), ensuring high
              performance and scalability in production environments
            </li>
            <li>
              • Defined and maintained RESTful APIs on AWS, integrating cloud-native components
              aligned with best architecture practices
            </li>
            <li>
              • Managed production deployments, troubleshooting incidents and optimizing response
              times for critical services
            </li>
            <li>
              • Designed and implemented PostgreSQL schemas, stored procedures, and tables to
              support transactional and analytical operations
            </li>
          </ul>
          <div class="mt-4 flex flex-wrap gap-2">
            {['Java', 'Vert.x', 'Spring Boot', 'AWS', 'PostgreSQL'].map((t) => <Tag label={t} />)}
          </div>
        </div>

        <div class="rounded-xl border border-border bg-surface p-6">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="font-semibold text-text-primary">Software Engineer</h3>
              <p class="text-muted">Buk</p>
            </div>
            <span class="shrink-0 font-mono text-sm text-violet-400">Oct 2023 – Apr 2024</span>
          </div>
          <ul class="mt-3 space-y-1 text-sm text-muted">
            <li>
              • Developed and maintained core features within a Groovy-based monolithic application,
              improving stability and performance across multiple business modules
            </li>
            <li>
              • Resolved production incidents and customer-reported issues, ensuring high system
              availability and reliability
            </li>
            <li>
              • Designed and delivered new functionalities and enhancements, aligning with product
              requirements and agile delivery timelines
            </li>
          </ul>
          <div class="mt-4 flex flex-wrap gap-2">
            {['Groovy', 'Monolith', 'Agile'].map((t) => <Tag label={t} />)}
          </div>
        </div>

        <div class="rounded-xl border border-border bg-surface p-6">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="font-semibold text-text-primary">Senior Java Software Engineer</h3>
              <p class="text-muted">Globant</p>
            </div>
            <span class="shrink-0 font-mono text-sm text-violet-400">Feb 2022 – Sep 2023</span>
          </div>
          <ul class="mt-3 space-y-1 text-sm text-muted">
            <li>
              • Developed and implemented new features for financial systems using Java, enhancing
              process efficiency and transaction reliability
            </li>
            <li>
              • Produced technical documentation and deployment guides, ensuring seamless delivery
              and consistent application rollout across environments
            </li>
            <li>
              • Collaborated with cross-functional teams (QA, DevOps, Product, and Architecture) to
              align development efforts with business objectives
            </li>
          </ul>
          <div class="mt-4 flex flex-wrap gap-2">
            {['Java', 'Financial Systems', 'Cross-functional'].map((t) => <Tag label={t} />)}
          </div>
        </div>

        <div class="rounded-xl border border-border bg-surface p-6">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="font-semibold text-text-primary">Software Engineer</h3>
              <p class="text-muted">Subastas Ventura</p>
            </div>
            <span class="shrink-0 font-mono text-sm text-violet-400">Dec 2020 – Feb 2022</span>
          </div>
          <ul class="mt-3 space-y-1 text-sm text-muted">
            <li>
              • Led the migration from SVN to GitLab, serving as repository administrator and
              implementing branch and merge strategies aligned with CI/CD best practices
            </li>
            <li>
              • Integrated SonarQube for static code analysis, improving code quality and reducing
              technical debt
            </li>
            <li>
              • Planned and initiated the transition from a monolithic system to a microservices
              architecture, defining core services and modular boundaries
            </li>
          </ul>
          <div class="mt-4 flex flex-wrap gap-2">
            {['GitLab', 'SonarQube', 'Microservices', 'CI/CD'].map((t) => <Tag label={t} />)}
          </div>
        </div>

        <div class="rounded-xl border border-border bg-surface p-6">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="font-semibold text-text-primary">Java Software Engineer</h3>
              <p class="text-muted">GFT</p>
            </div>
            <span class="shrink-0 font-mono text-sm text-violet-400">Apr 2020 – Sep 2020</span>
          </div>
          <ul class="mt-3 space-y-1 text-sm text-muted">
            <li>
              • Developed and integrated microservices into the Banking-as-a-Service (BaaS)
              architecture, ensuring secure and efficient data exchange
            </li>
            <li>
              • Built reactive applications using Spring Boot WebFlux, improving system
              responsiveness and scalability under high load
            </li>
            <li>
              • Implemented MongoDB and Redis for optimised data access and caching, enhancing
              performance and reducing latency
            </li>
          </ul>
          <div class="mt-4 flex flex-wrap gap-2">
            {['Spring Boot', 'WebFlux', 'MongoDB', 'Redis', 'BaaS'].map((t) => <Tag label={t} />)}
          </div>
        </div>

        <div class="rounded-xl border border-border bg-surface p-6">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="font-semibold text-text-primary">Java Software Engineer</h3>
              <p class="text-muted">4Work (Consis Internacional)</p>
            </div>
            <span class="shrink-0 font-mono text-sm text-violet-400">Dec 2019 – Mar 2020</span>
          </div>
          <ul class="mt-3 space-y-1 text-sm text-muted">
            <li>
              • Contributed to the development and maintenance of enterprise-grade Java applications
            </li>
            <li>
              • Designed and implemented RESTful APIs and web services using Hibernate, JSF, and
              Maven
            </li>
            <li>
              • Conducted code reviews, unit testing, and applied object-oriented programming
              principles
            </li>
          </ul>
          <div class="mt-4 flex flex-wrap gap-2">
            {['Java', 'Hibernate', 'JSF', 'Maven', 'REST APIs'].map((t) => <Tag label={t} />)}
          </div>
        </div>

        <div class="rounded-xl border border-border bg-surface p-6">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="font-semibold text-text-primary">IT Consultant</h3>
              <p class="text-muted">SOA Professionals Latam</p>
            </div>
            <span class="shrink-0 font-mono text-sm text-violet-400">Nov 2017 – Dec 2019</span>
          </div>
          <ul class="mt-3 space-y-1 text-sm text-muted">
            <li>
              • Served as Software Engineer for multiple banking integration projects, delivering
              high-availability solutions
            </li>
            <li>
              • Led data migration project for Scotiabank (CMOD migration, Jun–Dec 2018),
              manipulating AIX-IBM server data from e2vault to CMOD
            </li>
            <li>
              • Developed and maintained Java-based APIs and web services using Hibernate, XML, and
              OOP principles
            </li>
            <li>
              • Applied Clean Code and agile methodologies to ensure maintainable, secure, and
              efficient codebases
            </li>
          </ul>
          <div class="mt-4 flex flex-wrap gap-2">
            {
              ['Java', 'Hibernate', 'XML', 'Banking', 'Scotiabank', 'Clean Code'].map((t) => (
                <Tag label={t} />
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <div class="mb-12">
      <h2 class="mb-6 text-xl font-bold text-text-primary">Technical Skills</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-border bg-surface p-4">
          <h3 class="mb-2 text-sm font-semibold text-violet-400">Programming Languages</h3>
          <p class="text-sm text-muted">Java, Go, Rust, Python, JavaScript, TypeScript, SQL</p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-4">
          <h3 class="mb-2 text-sm font-semibold text-violet-400">Frameworks & Libraries</h3>
          <p class="text-sm text-muted">
            Spring Boot, Spring Framework, Vert.x, Hibernate, Jakarta EE, JSF, Maven, WebFlux
          </p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-4">
          <h3 class="mb-2 text-sm font-semibold text-violet-400">Cloud & DevOps</h3>
          <p class="text-sm text-muted">
            AWS, Docker, Kubernetes (EKS), Terraform, Jenkins, GitHub Actions, SonarQube, CI/CD
            Pipelines, New Relic, Elasticsearch
          </p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-4">
          <h3 class="mb-2 text-sm font-semibold text-violet-400">Databases</h3>
          <p class="text-sm text-muted">
            PostgreSQL, MongoDB, Redis, SQL Server, MySQL, MariaDB, DynamoDB
          </p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-4">
          <h3 class="mb-2 text-sm font-semibold text-violet-400">Architecture & Practices</h3>
          <p class="text-sm text-muted">
            Microservices, Cloud-Native Architecture, Distributed Systems, API Design, Clean Code,
            Agile Methodologies, OOP, Design Patterns
          </p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-4">
          <h3 class="mb-2 text-sm font-semibold text-violet-400">Soft Skills</h3>
          <p class="text-sm text-muted">
            Technical Leadership, Project Management, Problem Solving, Team Collaboration,
            Analytical Thinking
          </p>
        </div>
      </div>
    </div>

    <div class="mb-12">
      <h2 class="mb-6 text-xl font-bold text-text-primary">Education</h2>
      <div class="rounded-xl border border-border bg-surface p-6">
        <h3 class="font-semibold text-text-primary">Computer Engineering</h3>
        <p class="text-muted">Universidad Politécnica de Sinaloa</p>
        <p class="font-mono text-sm text-violet-400">2011 – 2014</p>
      </div>
    </div>

    <div class="mb-12">
      <h2 class="mb-6 text-xl font-bold text-text-primary">Certifications</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-border bg-surface p-4">
          <h3 class="font-semibold text-text-primary">Scrum Developer Certified (SDC)</h3>
          <p class="text-sm text-muted">SCRUMstudy · Dec 2015</p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-4">
          <h3 class="font-semibold text-text-primary">Scrum Fundamentals Certified (SFC)</h3>
          <p class="text-sm text-muted">SCRUMstudy · Dec 2015</p>
        </div>
        <div class="rounded-xl border border-dashed border-violet-500/30 bg-surface p-4">
          <h3 class="font-semibold text-text-primary">AWS Solutions Architect</h3>
          <p class="text-sm text-muted">Amazon Web Services · In Progress</p>
        </div>
      </div>
    </div>

    <div class="mb-12">
      <h2 class="mb-6 text-xl font-bold text-text-primary">Professional Development</h2>
      <p class="mb-4 text-sm leading-relaxed text-muted">
        Continuous training through Platzi and Udemy, completing courses in databases, programming,
        DevOps, and software architecture. Committed to lifelong learning and staying current with
        emerging technologies and cloud-native design patterns.
      </p>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl border border-border bg-surface p-4">
          <h3 class="mb-3 text-sm font-semibold text-violet-400">Platzi Courses</h3>
          <ul class="space-y-1 text-sm text-muted">
            <li>• Databases</li>
            <li>• PostgreSQL</li>
            <li>• SQL and MySQL</li>
            <li>• Programming Fundamentals</li>
            <li>• Professional Git and GitHub</li>
            <li>• Java</li>
            <li>• Online Web Development</li>
            <li>• Introduction to Terminal and Command Line</li>
          </ul>
        </div>
        <div class="rounded-xl border border-border bg-surface p-4">
          <h3 class="mb-3 text-sm font-semibold text-violet-400">Continuing Education</h3>
          <ul class="space-y-1 text-sm text-muted">
            <li>• Software Architecture</li>
            <li>• Microservices Design Patterns</li>
            <li>• AWS Cloud Services</li>
            <li>• Java Performance Optimisation</li>
            <li>• Clean Architecture</li>
            <li>• DevOps Fundamentals</li>
          </ul>
        </div>
      </div>
    </div>

    <div>
      <h2 class="mb-6 text-xl font-bold text-text-primary">Additional Information</h2>
      <div class="grid gap-4 sm:grid-cols-3">
        <div class="rounded-xl border border-border bg-surface p-4">
          <h3 class="mb-2 text-sm font-semibold text-violet-400">Languages</h3>
          <p class="text-sm text-muted">Spanish — Native</p>
          <p class="text-sm text-muted">English — Professional working proficiency</p>
          <p class="text-sm text-muted">Japanese — Elementary</p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-4">
          <h3 class="mb-2 text-sm font-semibold text-violet-400">Work Preferences</h3>
          <p class="text-sm text-muted">Open to remote, hybrid, or on-site roles</p>
          <p class="text-sm text-muted">Scrum methodology, team leadership</p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-4">
          <h3 class="mb-2 text-sm font-semibold text-violet-400">Online Presence</h3>
          <p class="text-sm text-muted">30,000+ points on Platzi</p>
          <p class="text-sm text-muted">500+ LinkedIn connections</p>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>
