---
import BaseLayout from '@layouts/BaseLayout.astro';
import JsonLd from '@components/seo/JsonLd.astro';
import Section from '@components/layout/Section.astro';
import Tag from '@components/ui/Tag.astro';
import CTA from '@components/ui/CTA.astro';
import { Image } from 'astro:assets';
import profileImage from '../assets/profile/profile-original.jpg';

const specialties = [
  'Hexagonal Architecture',
  'Clean Architecture',
  'Domain-Driven Design',
  'CQRS',
  'Event-Driven Architecture',
  'Microservices',
  'Event Sourcing',
  'Reactive Systems',
  'Axum',
];

const experience = [
  {
    year: '2024–2025',
    role: 'Software Architect',
    company: 'Smart Payment Services',
    tech: ['Rust', 'Java', 'Go', 'Python', 'AWS'],
  },
  {
    year: '2023–2024',
    role: 'Software Engineer',
    company: 'Buk',
    tech: ['Groovy', 'Monolith', 'Agile'],
  },
  {
    year: '2022–2023',
    role: 'Senior Java Software Engineer',
    company: 'Globant',
    tech: ['Java', 'Financial Systems', 'Cross-functional'],
  },
  {
    year: '2020–2022',
    role: 'Software Engineer',
    company: 'Subastas Ventura',
    tech: ['GitLab', 'SonarQube', 'Microservices', 'CI/CD'],
  },
  {
    year: '2017–2020',
    role: 'Java Software Engineer',
    company: 'GFT · 4Work · SOA Professionals Latam',
    tech: ['Java', 'Spring Boot', 'Hibernate', 'Banking'],
  },
];
---

<BaseLayout
  title="About — Kristian López"
  ogTitle="About Kristian López — Software Architect & Staff Engineer"
  description="Software Architect and Staff Engineer building distributed systems, microservices, and cloud-native platforms."
  image="/og/og-about.png"
>
  <JsonLd type="Person" />
  <Section>
    <div class="grid gap-10 md:grid-cols-[1fr_280px] md:items-start">
      <div class="max-w-3xl">
        <h1 class="mb-6 text-4xl font-bold text-text-primary">About Me</h1>

        <div class="space-y-4 text-lg leading-relaxed text-muted">
          <p>
            I'm Kristian López, a Software Architect and Technical Leader with over 9 years of
            experience designing and implementing cloud-native architectures and microservices
            solutions. I've led teams of 4–8 engineers to deliver scalable, secure, and
            high-performance systems on AWS using Java, Go, Python, and Rust.
          </p>
          <p>
            My engineering philosophy is simple:
            <strong class="text-text-primary">complexity is a cost center</strong>. I design for
            replaceability and fast feedback, so components can be tested, evolved, and reasoned
            about independently. I rely on Clean Architecture, Microservices, and cloud-native
            patterns because they reduce long-term friction.
          </p>
          <p>
            Outside architecture decisions, I write about production trade-offs, CI/CD automation,
            and share practical patterns for cloud-native development and software optimisation.
          </p>
        </div>
      </div>
      <div class="mx-auto w-full max-w-[240px] md:justify-self-end">
        <Image
          src={profileImage}
          alt="Portrait of Kristian López"
          widths={[240, 320, 400]}
          sizes="(max-width: 768px) 220px, 240px"
          format="webp"
          loading="lazy"
          class="aspect-square rounded-2xl border border-border object-cover shadow-lg shadow-violet-500/10"
        />
      </div>
    </div>
  </Section>

  <Section class="border-t border-border">
    <h2 class="mb-8 text-2xl font-bold text-text-primary">Specialties</h2>
    <div class="flex flex-wrap gap-3">
      {specialties.map((s) => <Tag label={s} />)}
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      <div class="rounded-xl border border-border bg-surface p-6">
        <h3 class="mb-3 font-semibold text-text-primary">Architecture Principles</h3>
        <ul class="space-y-2 text-sm text-muted">
          <li>• Ports & Adapters (Hexagonal) as the default shape</li>
          <li>• Bounded contexts over shared databases</li>
          <li>• Event-first design — facts, not commands</li>
          <li>• Testability as a first-class design constraint</li>
          <li>• Evolutionary architecture over big-bang rewrites</li>
        </ul>
      </div>
      <div class="rounded-xl border border-border bg-surface p-6">
        <h3 class="mb-3 font-semibold text-text-primary">Cloud & Infrastructure</h3>
        <ul class="space-y-2 text-sm text-muted">
          <li>• AWS: EKS, S3, SQS, SNS, Secrets Manager, IAM</li>
          <li>• Kubernetes: workloads, RBAC, Helm, GitOps</li>
          <li>• Observability: OpenTelemetry, Prometheus, Grafana</li>
          <li>• CI/CD: GitHub Actions, Jenkins</li>
          <li>• IaC: Terraform</li>
          <li>• Event Streaming: Kafka</li>
        </ul>
      </div>
    </div>
    <p class="mt-4 text-xs italic text-muted">
      AWS Solutions Architect certification — in progress
    </p>
  </Section>

  <Section class="border-t border-border">
    <h2 class="mb-8 text-2xl font-bold text-text-primary">Experience</h2>
    <div class="space-y-6">
      {
        experience.map(({ year, role, company, tech }) => (
          <div class="flex gap-6 rounded-xl border border-border bg-surface p-6">
            <div class="w-28 shrink-0">
              <span class="font-mono text-sm text-violet-400">{year}</span>
            </div>
            <div>
              <p class="font-semibold text-text-primary">{role}</p>
              <p class="mb-3 text-sm text-muted">{company}</p>
              <div class="flex flex-wrap gap-2">
                {tech.map((t) => (
                  <span class="rounded bg-surface-hover px-2 py-0.5 text-xs text-muted">{t}</span>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </Section>

  <Section class="border-t border-border">
    <div class="flex flex-wrap gap-4">
      <CTA href="/resume" variant="primary" trackEvent="cta-click" trackLabel="View full resume"
        >View full resume →</CTA
      >
      <CTA href="/contact" variant="secondary" trackEvent="cta-click" trackLabel="Let's talk"
        >Let's talk</CTA
      >
    </div>
  </Section>
</BaseLayout>
