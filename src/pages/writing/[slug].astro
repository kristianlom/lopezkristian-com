---
import PostLayout from '@layouts/PostLayout.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '@utils/reading-time';

export async function getStaticPaths() {
  const posts = (await getCollection('writing', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

  // Build a tag -> posts index once to avoid O(n^2) scans.
  const tagIndex = new Map<string, typeof posts>();
  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      if (!tagIndex.has(tag)) tagIndex.set(tag, []);
      tagIndex.get(tag)!.push(post);
    }
  }

  return posts.map((post, index, allPosts) => {
    const prevPost = allPosts[index - 1];
    const nextPost = allPosts[index + 1];

    const candidateScores = new Map<string, { post: (typeof posts)[number]; score: number }>();
    for (const tag of post.data.tags ?? []) {
      for (const candidate of tagIndex.get(tag) ?? []) {
        if (candidate.slug === post.slug) continue;
        const existing = candidateScores.get(candidate.slug) ?? { post: candidate, score: 0 };
        existing.score += 1;
        candidateScores.set(candidate.slug, existing);
      }
    }

    const relatedPosts = Array.from(candidateScores.values())
      .sort(
        (a, b) =>
          b.score - a.score ||
          b.post.data.pubDate.getTime() - a.post.data.pubDate.getTime(),
      )
      .slice(0, 3)
      .map(({ post: related }) => related);

    return {
      params: { slug: post.slug },
      props: {
        post,
        prevPost,
        nextPost,
        relatedPosts,
      },
    };
  });
}

const { post, prevPost, nextPost, relatedPosts } = Astro.props;
const { Content, headings } = await post.render();
const readingTime = getReadingTime(post.body);
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  heroImage={post.data.heroImage}
  headings={headings}
  readingTime={readingTime}
  slug={post.slug}
  prevPost={prevPost}
  nextPost={nextPost}
  relatedPosts={relatedPosts}
>
  <Content />
</PostLayout>
