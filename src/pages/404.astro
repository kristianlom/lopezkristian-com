---
import BaseLayout from '@layouts/BaseLayout.astro';
import CTA from '@components/ui/CTA.astro';
---

<BaseLayout
  title="404 — Page Not Found | Kristian López"
  description="The page you're looking for doesn't exist."
>
  <div class="flex min-h-[70vh] flex-col items-center justify-center px-6 text-center">
    <p class="mb-4 font-mono text-6xl font-bold text-violet-600">404</p>
    <h1 class="mb-4 text-3xl font-bold text-text-primary">Page Not Found</h1>
    <p class="mb-8 max-w-md text-muted">
      The page you're looking for doesn't exist or has been moved. 
      Let's get you back on track.
    </p>
    <div class="mb-8 flex flex-wrap justify-center gap-3">
      <CTA href="/" variant="primary">Back to Home →</CTA>
      <CTA href="/writing" variant="secondary">Go to Writing</CTA>
      <CTA href="/contact" variant="secondary">Contact</CTA>
    </div>

    <div class="w-full max-w-lg rounded-xl border border-border bg-surface p-5 text-left">
      <p class="mb-3 text-sm font-semibold text-text-primary">Try one of these:</p>
      <ul class="space-y-2 text-sm text-muted">
        <li><a class="hover:text-violet-400" href="/about">About</a></li>
        <li><a class="hover:text-violet-400" href="/projects">Projects</a></li>
        <li><a class="hover:text-violet-400" href="/writing">Latest articles</a></li>
      </ul>
    </div>
  </div>
</BaseLayout>
