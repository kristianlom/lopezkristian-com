# ─── Variables de entorno locales ────────────────────────────────────────────
# Copia este archivo a .env.local:  cp .env.example .env.local
# NUNCA commitear .env.local — está en .gitignore.

# Astro
PUBLIC_SITE_URL=http://localhost:4321

# Analytics (dejar vacío para deshabilitar tracking)
PUBLIC_ANALYTICS_ID=

# AWS (solo si usas AWS CLI localmente)
# AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_PROFILE=

# Formulario de contacto (Resend, Formspree, etc.)
# RESEND_API_KEY=
